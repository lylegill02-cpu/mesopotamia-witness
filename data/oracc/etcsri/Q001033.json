      "para_id": "Q001033.1",
      "line_range": "1",
      "translation": "(i 1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the Ebgal ."
    },
    {
      "para_id": "Q001033.8",
      "line_range": "8",
      "translation": "(ii 4) He built the Kinir ."
    },
    {
      "para_id": "Q001033.10",
      "line_range": "10",
      "translation": "(ii 6) He built the Nine-ĝara ."
    },
    {
      "para_id": "Q001033.12",
      "line_range": "12",
      "translation": "(iii 2) He built the Bagara ."
    },
    {
      "para_id": "Q001033.14",
      "line_range": "14",
      "translation": "(iii 4) He built the E-dam ."
    },
    {
      "para_id": "Q001033.16",
      "line_range": "16",
      "translation": "(iii 6) He built the Tiraš"
    },
    {
      "para_id": "Q001033.18",
      "line_range": "18",
      "translation": "(iv 2) He built the A-eden ."
    },
    {
      "para_id": "Q001033.20",
      "line_range": "20",
      "translation": "(iv 4) He built the E-ĝidru ."
    }
  ],
