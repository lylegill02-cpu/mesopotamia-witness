  "paragraphs": [
    {
      "para_id": "Q001036.1",
      "line_range": "1",
      "translation": "(1) To Ninĝirsu , when he built for him the shrine of Ĝirsu , Ur-Nanše , king of Lagaš , child of Gunidu , dedicated this ( door socket ) ."
    },
    {
      "para_id": "Q001036.9",
      "line_range": "9",
      "translation": "(9) He built the temple of Nanše ."
    },
    {
      "para_id": "Q001036.11",
      "line_range": "11",
      "translation": "(11) He built the Ebgal ."
    },
    {
      "para_id": "Q001036.13",
      "line_range": "13",
      "translation": "(13) He built the Kinir ."
    },
    {
      "para_id": "Q001036.15",
      "line_range": "15",
      "translation": "(15) He built the Bagara ."
    },
    {
      "para_id": "Q001036.17",
      "line_range": "17",
      "translation": "(17) He built the E-dam ."
    },
    {
      "para_id": "Q001036.19",
      "line_range": "19",
      "translation": "(19) He built the temple of Ĝatumdug ."
    },
    {
      "para_id": "Q001036.21",
      "line_range": "21",
      "translation": "(21) He built the Tiraš ."
    }
  ],
