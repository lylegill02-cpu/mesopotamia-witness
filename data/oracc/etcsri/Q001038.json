  "paragraphs": [
    {
      "para_id": "Q001038.1",
      "line_range": "1",
      "translation": "(1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the temple of Ninĝirsu ."
    },
    {
      "para_id": "Q001038.8",
      "line_range": "8",
      "translation": "(8) He built the temple of Nanše ."
    },
    {
      "para_id": "Q001038.10",
      "line_range": "10",
      "translation": "(10) He built the Šeše-ĝara ."
    },
    {
      "para_id": "Q001038.12",
      "line_range": "12",
      "translation": "(12) He built the Abzu-banda ."
    },
    {
      "para_id": "Q001038.14",
      "line_range": "14",
      "translation": "(14) He built the Bagara ."
    },
    {
      "para_id": "Q001038.16",
      "line_range": "16",
      "translation": "(16) He established control of the Dilmun-boats ( coming ) from the foreign countries ."
    }
  ],
