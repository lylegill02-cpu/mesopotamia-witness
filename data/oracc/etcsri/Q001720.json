  "paragraphs": [
    {
      "para_id": "Q001720.1",
      "line_range": "1",
      "translation": "(1) To Ninlil , his lady , Šulgi , the powerful man , king of Urim , king of Sumer and Akkad , dedicated this ( bead ) for his own well-being and for the well-being of Ninturturĝu , his beloved child ."
    },
    {
      "para_id": "Q001720.12",
      "line_range": "12",
      "translation": "(12) Whoever erases this inscription , may my lady , Ninlil , curse him !"
    }
  ],
