    {
      "para_id": "Q001031.1",
      "line_range": "1",
      "translation": "(i 1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the temple of Nanše ."
    },
    {
      "para_id": "Q001031.8",
      "line_range": "8",
      "translation": "(ii 4) He built the shrine of Ĝirsu ."
    },
    {
      "para_id": "Q001031.10",
      "line_range": "10",
      "translation": "(iii 2) He built the Ebgal ."
    },
    {
      "para_id": "Q001031.12",
      "line_range": "12",
      "translation": "(iii 4) He built the Kinir ."
    },
    {
      "para_id": "Q001031.14",
      "line_range": "14",
      "translation": "(iii 6) He built the E-dam ."
    },
    {
      "para_id": "Q001031.16",
      "line_range": "16",
      "translation": "(iv 2) He built the Bagara ."
    },
    {
      "para_id": "Q001031.18",
      "line_range": "18",
      "translation": "(iv 4) He built the Abzu-ega ."
    }
  ],
