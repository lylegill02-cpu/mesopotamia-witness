  "paragraphs": [
    {
      "para_id": "Q001037.1",
      "line_range": "1",
      "translation": "(1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the temple of Ninĝirsu ."
    },
    {
      "para_id": "Q001037.8",
      "line_range": "8",
      "translation": "(8) He built the temple of Nanše ."
    },
    {
      "para_id": "Q001037.10",
      "line_range": "10",
      "translation": "(10) He built the temple of Ĝatumdug ."
    },
    {
      "para_id": "Q001037.12",
      "line_range": "12",
      "translation": "(12) He built the E-dam ."
    },
    {
      "para_id": "Q001037.14",
      "line_range": "14",
      "translation": "(14) He built the temple of Ninmarki ."
    },
    {
      "para_id": "Q001037.16",
      "line_range": "16",
      "translation": "(16) He established control of the Dilmun-boats ( coming ) from the foreign countries ."
    },
    {
      "para_id": "Q001037.19",
      "line_range": "19",
      "translation": "(19) He built the Ebgal ."
    },
    {
      "para_id": "Q001037.21",
      "line_range": "21",
      "translation": "(21) He built the Kinir ."
    },
    {
      "para_id": "Q001037.23",
      "line_range": "23",
      "translation": "(23) He built the E-ĝidru ."
    }
  ],
