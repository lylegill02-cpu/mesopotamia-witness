    {
      "para_id": "Q004247.1",
      "line_range": "1",
      "translation": "(1) To Ninšubur , Ur-akkila , the barber , dedicated this ( stone tablet ) for his own well-being ."
    },
    {
      "para_id": "Q004247.5",
      "line_range": "5",
      "translation": "(5) His spouse is Gan-Utu ."
    },
    {
      "para_id": "Q004247.7",
      "line_range": "7",
      "translation": "(7) His children are Gan-šubur , Me-kikugta , Ursaĝ-Utu , Inim-Utu-zid , ..., ..., ..., Nin-izuzu ."
    }
  ],
