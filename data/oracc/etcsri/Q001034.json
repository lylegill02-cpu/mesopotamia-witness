    {
      "para_id": "Q001034.1",
      "line_range": "1",
      "translation": "(i 1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the temple of Nanše ."
    },
    {
      "para_id": "Q001034.8",
      "line_range": "8",
      "translation": "(ii 3) He built the shrine of Ĝirsu ."
    },
    {
      "para_id": "Q001034.10",
      "line_range": "10",
      "translation": "(ii 5) He built the temple of Ĝatumdug ."
    },
    {
      "para_id": "Q001034.12",
      "line_range": "12",
      "translation": "(iii 1) He built the E-ĝidru ."
    },
    {
      "para_id": "Q001034.15",
      "line_range": "15",
      "translation": "(iii 5) He built the E-dam ."
    },
    {
      "para_id": "Q001034.17",
      "line_range": "17",
      "translation": "(iv 1) He built the Nine-ĝara ."
    },
    {
      "para_id": "Q001034.19",
      "line_range": "19",
      "translation": "(iv 3) He built the Bagara ."
    },
    {
      "para_id": "Q001034.21",
      "line_range": "21",
      "translation": "(iv 5) He built the Kinir ."
    }
  ],
