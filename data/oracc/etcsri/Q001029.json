    {
      "para_id": "Q001029.1",
      "line_range": "1",
      "translation": "(i 1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the shrine of Ĝirsu ."
    },
    {
      "para_id": "Q001029.8",
      "line_range": "8",
      "translation": "(ii 4) He built the temple of Nanše ."
    },
    {
      "para_id": "Q001029.10",
      "line_range": "10",
      "translation": "(iii 1) He built the Ebgal ."
    },
    {
      "para_id": "Q001029.12",
      "line_range": "12",
      "translation": "(iii 3) He built the Kinir ."
    },
    {
      "para_id": "Q001029.14",
      "line_range": "14",
      "translation": "(iv 1) He built the temple of Ĝatumdug ."
    },
    {
      "para_id": "Q001029.16",
      "line_range": "16",
      "translation": "(iv 3) He built the Abzu-ega ."
    },
    {
      "para_id": "Q001029.18",
      "line_range": "18",
      "translation": "(iv 5) He built the Tiraš ."
    },
    {
      "para_id": "Q001029.20",
      "line_range": "20",
      "translation": "(v 1) He built the shrine of Bagara ."
    },
    {
      "para_id": "Q001029.22",
      "line_range": "22",
      "translation": "(v 3) He built the E-dam ."
    },
    {
      "para_id": "Q001029.24",
      "line_range": "24",
      "translation": "(v 5) He built the Kame ."
    }
  ],
