    {
      "para_id": "Q001030.1",
      "line_range": "1",
      "translation": "(i 1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the temple of Nanše ."
    },
    {
      "para_id": "Q001030.8",
      "line_range": "8",
      "translation": "(ii 4) He built the shrine of Ĝirsu ."
    },
    {
      "para_id": "Q001030.10",
      "line_range": "10",
      "translation": "(iii 1) He built the Ebgal ."
    },
    {
      "para_id": "Q001030.12",
      "line_range": "12",
      "translation": "(iii 3) He built the E-ĝidru ."
    },
    {
      "para_id": "Q001030.14",
      "line_range": "14",
      "translation": "(iii 5) He built the temple of Ĝatumdug ."
    },
    {
      "para_id": "Q001030.16",
      "line_range": "16",
      "translation": "(iv 2) He built the temple of Ninmarki ."
    },
    {
      "para_id": "Q001030.18",
      "line_range": "18",
      "translation": "(iv 4) He built the E-dam ."
    }
  ],
