  "title": "Rimuš 18 (Sumerian) (RIME 2.01.02.18 composite)",
  "language": "sumerian",
  "translation_source": "ORACC ETCSRI — CC BY-SA 3.0",
  "source_url": "https://oracc.museum.upenn.edu/etcsri/Q000842",
  "paragraphs": [
    {
      "para_id": "Q000842.1",
      "line_range": "1",
      "translation": "(1) Rimuš , king of the world : Since the dawn of time no one had ever fashioned a tin statue for Enlil , ( but now ) Rimuš , king of the world fashioned a tin statue of himself and set it up before Enlil . He counted himself among the gods ."
    },
    {
      "para_id": "Q000842.20",
      "line_range": "20",
      "translation": "(20) Whoever obliterates this inscription , may Enlil and Utu uproot him and destroy his lineage !"
    },
    {
      "para_id": "Q000842.28",
      "line_range": "28",
      "translation": "(colophon 1, 1) Inscription of a šahum cauldron ."
    },
    {
      "para_id": "Q000842.29",
      "line_range": "29",
      "translation": "(colophon 2, 1) Inscription ... of Rimuš ."
    }
  ],
