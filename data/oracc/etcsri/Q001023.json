      "para_id": "Q001023.1",
      "line_range": "1",
      "translation": "(1) Ur-Nanše , king of Lagaš , child of Gunidu , built the temple of Ninĝirsu ."
    },
    {
      "para_id": "Q001023.7",
      "line_range": "7",
      "translation": "(7) He built the temple of Nanše ."
    },
    {
      "para_id": "Q001023.9",
      "line_range": "9",
      "translation": "(9) He built the Abzu-banda ."
    },
    {
      "para_id": "Q001023.11",
      "line_range": "11",
      "translation": "(11) He built the Šeše-ĝara ."
    },
    {
      "para_id": "Q001023.13",
      "line_range": "13",
      "translation": "(Upper Captions, 1') Awil-kinatum ."
    },
    {
      "para_id": "Q001023.14",
      "line_range": "14",
      "translation": "(Upper Captions, 2') Lugal-ezen , child ."
    },
    {
      "para_id": "Q001023.15",
      "line_range": "15",
      "translation": "(Upper Captions, 3') Mukuršubata , child ."
    },
    {
      "para_id": "Q001023.16",
      "line_range": "16",
      "translation": "(Upper Captions, 4') Hursaĝše-mah"
    },
    {
      "para_id": "Q001023.17",
      "line_range": "17",
      "translation": "(Lower Captions, 1) Anita"
    },
    {
      "para_id": "Q001023.18",
      "line_range": "18",
      "translation": "(Lower Captions, 2) Balu , chief snake charmer ."
    },
    {
      "para_id": "Q001023.19",
      "line_range": "19",
      "translation": "(Lower Captions, 3) Aja-kurgal , child ."
    },
    {
      "para_id": "Q001023.20",
      "line_range": "20",
      "translation": "(Lower Captions, 4) Namazu , scribe ."
    }
