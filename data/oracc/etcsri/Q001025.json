  "paragraphs": [
    {
      "para_id": "Q001025.1",
      "line_range": "1",
      "translation": "(i 1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the temple of Nanše ."
    },
    {
      "para_id": "Q001025.8",
      "line_range": "8",
      "translation": "(ii 1) He fashioned ( the statue of ) Nanše ."
    },
    {
      "para_id": "Q001025.10",
      "line_range": "10",
      "translation": "(ii 3) He dug the ... canal , and ... water into the ... canal for Nanše ."
    },
    {
      "para_id": "Q001025.15",
      "line_range": "15",
      "translation": "(iii 1) He fashioned ( the statue of ) Ešir ."
    },
    {
      "para_id": "Q001025.17",
      "line_range": "17",
      "translation": "(iii 3) He chose Ur-nimin ( as ) the spouse of Nanše by extispicy ."
    },
    {
      "para_id": "Q001025.21",
      "line_range": "21",
      "translation": "(iii 7) He built the A-eden ."
    },
    {
      "para_id": "Q001025.23",
      "line_range": "23",
      "translation": "(iv 1) He built the Nine-ĝara ."
    },
    {
      "para_id": "Q001025.25",
      "line_range": "25",
      "translation": "(iv 3) He built the E-ĝidru ."
    },
    {
      "para_id": "Q001025.27",
      "line_range": "27",
      "translation": "(iv 5) He built the city wall of Lagaš ."
    },
    {
      "para_id": "Q001025.29",
      "line_range": "29",
      "translation": "(v 1) He fashioned ( the statue of ) Lugal-Uruba ."
    },
    {
      "para_id": "Q001025.31",
      "line_range": "31",
      "translation": "(v 3) He established control of the Dilmun-boats ( coming ) from the foreign countries ."
    }
  ],
