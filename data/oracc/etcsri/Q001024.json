      "para_id": "Q001024.1",
      "line_range": "1",
      "translation": "(Before Ur-Nanše, 1) Ur-Nanše , king of Lagaš , built the temple of Ninĝirsu ."
    },
    {
      "para_id": "Q001024.6",
      "line_range": "6",
      "translation": "(Before Ur-Nanše, 6) He built the Abzu-banda ."
    },
    {
      "para_id": "Q001024.8",
      "line_range": "8",
      "translation": "(After Ur-Nanše, i 1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the temple of Nanše ."
    },
    {
      "para_id": "Q001024.15",
      "line_range": "15",
      "translation": "(After Ur-Nanše, ii 3) He built the Šeše-ĝara ."
    },
    {
      "para_id": "Q001024.17",
      "line_range": "17",
      "translation": "(After Ur-Nanše, ii 5) He established control of the Dilmun-boats ."
    },
    {
      "para_id": "Q001024.19",
      "line_range": "19",
      "translation": "(Upper Captions, 1) Lugal-ezen , child ."
