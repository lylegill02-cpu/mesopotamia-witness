    {
      "para_id": "Q004880.1",
      "line_range": "1",
      "translation": "(1) To Ninĝirsu , the powerful warrior of Enlil , his master , Ur-Ninsumuna , governor of Lagaš , dedicated this ( bowl ) for his well-being ."
    },
    {
      "para_id": "Q004880.10",
      "line_range": "10",
      "translation": "(10) The name of this bowl is “May my master prolong my life!” ."
    }
  ],
