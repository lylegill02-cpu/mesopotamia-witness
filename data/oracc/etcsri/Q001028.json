    {
      "para_id": "Q001028.1",
      "line_range": "1",
      "translation": "(i 1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the temple of Nanše ."
    },
    {
      "para_id": "Q001028.8",
      "line_range": "8",
      "translation": "(ii 4) He built the shrine of Ĝirsu ."
    },
    {
      "para_id": "Q001028.10",
      "line_range": "10",
      "translation": "(iii 2) He dug the Ninĝirsuke-pada ( canal ) ...."
    },
    {
      "para_id": "Q001028.13",
      "line_range": "13",
      "translation": "(iv 1) He built the Abzu-ega ."
    },
    {
      "para_id": "Q001028.15",
      "line_range": "15",
      "translation": "(iv 3) He built the E-dam ."
    }
  ],
