  "paragraphs": [
    {
      "para_id": "Q001035.1",
      "line_range": "1",
      "translation": "(i 1) Ur-Nanše , king of Lagaš , child of Gunidu , built the temple of Ninĝirsu ."
    },
    {
      "para_id": "Q001035.7",
      "line_range": "7",
      "translation": "(i 7) He built the Ebgal ."
    },
    {
      "para_id": "Q001035.9",
      "line_range": "9",
      "translation": "(i 9) He built the temple of Nanše ."
    },
    {
      "para_id": "Q001035.11",
      "line_range": "11",
      "translation": "(ii 1) He built the Kinir ."
    },
    {
      "para_id": "Q001035.13",
      "line_range": "13",
      "translation": "(ii 3) He built the Bagara ."
    },
    {
      "para_id": "Q001035.15",
      "line_range": "15",
      "translation": "(ii 5) He built the E-dam ."
    },
    {
      "para_id": "Q001035.17",
      "line_range": "17",
      "translation": "(ii 7) He built the E-ĝidru ."
    },
    {
      "para_id": "Q001035.19",
      "line_range": "19",
      "translation": "(ii 9) He built the Šeše-ĝara ."
    },
    {
      "para_id": "Q001035.21",
      "line_range": "21",
      "translation": "(iii 1) He built the Tiraš ."
    },
    {
      "para_id": "Q001035.23",
      "line_range": "23",
      "translation": "(iii 3) He built the temple of Ĝatumdug ."
    },
    {
      "para_id": "Q001035.25",
      "line_range": "25",
      "translation": "(iii 5) He built the Abzu-ega ."
    },
    {
      "para_id": "Q001035.27",
      "line_range": "27",
      "translation": "(iii 7) When he built temple of Ninĝirsu , he provided the temple with 70 guru of barley ."
    },
    {
      "para_id": "Q001035.31",
      "line_range": "31",
      "translation": "(iv 1) He established control of the Dilmun-boats ( coming ) from the foreign countries ."
    },
    {
      "para_id": "Q001035.34",
      "line_range": "34",
      "translation": "(iv 4) He built the city wall of Lagaš ."
    },
    {
      "para_id": "Q001035.36",
      "line_range": "36",
      "translation": "(iv 6) He built the Abzu-banda ."
    },
    {
      "para_id": "Q001035.38",
      "line_range": "38",
      "translation": "(v 1) He fashioned ( the statue of ) Nanše , the mighty lady . He dug the ... canal , and ... water into the ... canal for her ."
    }
  ],
