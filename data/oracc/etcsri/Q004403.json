    {
      "para_id": "Q004403.1",
      "line_range": "1",
      "translation": "(1) To Ninĝirsu , the powerful warrior of Enlil , Lu-Ninĝirsu , the scribe , child of Lu-Bau , dedicated this ( bowl ) for his well-being and for the well-being of his spouse and child ."
    },
    {
      "para_id": "Q004403.11",
      "line_range": "11",
      "translation": "(11) The name of this bowl is \" My lady ...!\"."
    }
  ],
