  "paragraphs": [
    {
      "para_id": "Q001941.1",
      "line_range": "1",
      "translation": "(1) To Ninisina , his lady , Iddin-Dagan , the powerful king , king of Isin , king of Sumer and Akkad , dedicated this ( statue ) for his well-being ."
    },
    {
      "para_id": "Q001941.9",
      "line_range": "9",
      "translation": "(9) Whoever ... order to perform a misdeed ..., may Ninisina , my lady , and Damu , may master , curse him !"
    }
  ],
