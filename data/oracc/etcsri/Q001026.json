  "paragraphs": [
    {
      "para_id": "Q001026.1",
      "line_range": "1",
      "translation": "(i 1) Ur-Nanše , king of Lagaš , child of Gunidu , citizen of Gursar , built the temple of Nanše ."
    },
    {
      "para_id": "Q001026.8",
      "line_range": "8",
      "translation": "(ii 2) He fashioned ( the statue of ) Nanše , the mighty lady ."
    },
    {
      "para_id": "Q001026.10",
      "line_range": "10",
      "translation": "(ii 4) He built the shrine of Ĝirsu ."
    },
    {
      "para_id": "Q001026.11",
      "line_range": "11",
      "translation": "(ii 5) He fashioned ( the statue of ) Šul-šagana ."
    },
    {
      "para_id": "Q001026.13",
      "line_range": "13",
      "translation": "(ii 7) He built the Ebgal ."
    },
    {
      "para_id": "Q001026.15",
      "line_range": "15",
      "translation": "(iii 2) He fashioned ( the statue of ) Lugal-urtur ."
    },
    {
      "para_id": "Q001026.17",
      "line_range": "17",
      "translation": "(iii 4) He fashioned ( the statue of ) Lugal-Uruba ."
    },
    {
      "para_id": "Q001026.19",
      "line_range": "19",
      "translation": "(iii 6) He built the Kinir ."
    },
    {
      "para_id": "Q001026.21",
      "line_range": "21",
      "translation": "(iv 1) He fashioned ( the statue of ) Nineš-REC107 ."
    },
    {
      "para_id": "Q001026.23",
      "line_range": "23",
      "translation": "(iv 3) He fashioned ( the statue of ) Ninĝidru ."
    },
    {
      "para_id": "Q001026.25",
      "line_range": "25",
      "translation": "(iv 5) He built the temple of Ĝatumdug ."
    },
    {
      "para_id": "Q001026.27",
      "line_range": "27",
      "translation": "(iv 7) He fashioned ( the statue of ) Ĝatumdug ."
    },
    {
      "para_id": "Q001026.29",
      "line_range": "29",
      "translation": "(v 2) He built the Bagara ."
    },
    {
      "para_id": "Q001026.31",
      "line_range": "31",
      "translation": "(v 4) He built the Abzu-ega ."
    },
    {
      "para_id": "Q001026.33",
      "line_range": "33",
      "translation": "(v 6) He built the Tiraš ."
    }
  ],
